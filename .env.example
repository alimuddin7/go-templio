# Server
APP_ENV=development
APP_PORT=3000
APP_PREFORK=false

# Database
DB_DRIVER=sqlite       # sqlite | postgres
DB_DSN=./go-templio.db

# PostgreSQL (used when DB_DRIVER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=go_templio

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# Session
SESSION_SECRET=super-secret-session-key
SESSION_MAX_AGE=86400
