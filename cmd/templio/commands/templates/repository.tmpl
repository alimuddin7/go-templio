package {{.PackageName}}repo

import (
	"context"
	"database/sql"
	"errors"
	"time"

	"github.com/uptrace/bun"
	"{{.ModulePath}}/internal/domain/{{.PackageName}}"
)

type {{.PackageName}}Model struct {
	bun.BaseModel `bun:"table:{{.TableName}},alias:t"`

	ID        int64     `bun:"id,pk,autoincrement"`
	{{- range .Fields}}
	{{.GoName}} {{.GoType}} `bun:"{{.ColumnName}}"`
	{{- end}}
	CreatedAt time.Time `bun:"created_at,default:current_timestamp"`
	UpdatedAt time.Time `bun:"updated_at,default:current_timestamp"`
}

type Repository struct {
	db *bun.DB
}

func New(db *bun.DB) *Repository {
	return &Repository{db: db}
}

func (r *Repository) FindByID(ctx context.Context, id int64) (*{{.PackageName}}.{{.Name}}, error) {
	m := new({{.PackageName}}Model)
	err := r.db.NewSelect().Model(m).Where("id = ?", id).Scan(ctx)
	if err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return nil, errors.New("{{.PackageName}}: not found")
		}
		return nil, err
	}
	return toEntity(m), nil
}

func (r *Repository) List(ctx context.Context, search string, offset, limit int) ([]*{{.PackageName}}.{{.Name}}, int64, error) {
	var models []{{.PackageName}}Model
	q := r.db.NewSelect().Model(&models)

	if search != "" {
		q = q.WhereGroup(" AND ", func(sq *bun.SelectQuery) *bun.SelectQuery {
			{{- range $i, $field := .Fields }}
			{{- $column := .ColumnName }}
			{{- if or (eq .GoType "float64") (eq .GoType "int") (eq .GoType "int64") (eq .GoType "time.Time") }}
			{{- $column = printf "CAST(%s AS TEXT)" .ColumnName }}
			{{- end }}
			{{- if eq $i 0 }}
			sq = sq.Where("{{$column}} ILIKE ?", "%"+search+"%")
			{{- else }}
			sq = sq.WhereOr("{{$column}} ILIKE ?", "%"+search+"%")
			{{- end }}
			{{- end }}
			return sq
		})
	}

	total, err := q.OrderExpr("id ASC").Offset(offset).Limit(limit).ScanAndCount(ctx)
	if err != nil {
		return nil, 0, err
	}

	out := make([]*{{.PackageName}}.{{.Name}}, len(models))
	for i, m := range models {
		m := m
		out[i] = toEntity(&m)
	}
	return out, int64(total), nil
}

func (r *Repository) Create(ctx context.Context, ent *{{.PackageName}}.{{.Name}}) error {
	m := fromEntity(ent)
	m.CreatedAt = time.Now()
	m.UpdatedAt = time.Now()
	_, err := r.db.NewInsert().Model(m).Returning("id").Exec(ctx)
	if err == nil {
		ent.ID = m.ID
	}
	return err
}

func (r *Repository) Update(ctx context.Context, ent *{{.PackageName}}.{{.Name}}) error {
	m := fromEntity(ent)
	m.UpdatedAt = time.Now()
	_, err := r.db.NewUpdate().Model(m).Where("id = ?", m.ID).Exec(ctx)
	return err
}

func (r *Repository) Delete(ctx context.Context, id int64) error {
	_, err := r.db.NewDelete().Table("{{.TableName}}").Where("id = ?", id).Exec(ctx)
	return err
}

func toEntity(m *{{.PackageName}}Model) *{{.PackageName}}.{{.Name}} {
	return &{{.PackageName}}.{{.Name}}{
		ID:        m.ID,
		{{- range .Fields}}
		{{.GoName}}: m.{{.GoName}},
		{{- end}}
		CreatedAt: m.CreatedAt,
		UpdatedAt: m.UpdatedAt,
	}
}

func fromEntity(ent *{{.PackageName}}.{{.Name}}) *{{.PackageName}}Model {
	return &{{.PackageName}}Model{
		ID:        ent.ID,
		{{- range .Fields}}
		{{.GoName}}: ent.{{.GoName}},
		{{- end}}
		CreatedAt: ent.CreatedAt,
		UpdatedAt: ent.UpdatedAt,
	}
}
