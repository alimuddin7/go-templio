const (
	defaultPageSize = 20
	maxPageSize     = 100
)

// Service implements {{.PackageName}}.Service.
type Service struct {
	repo {{.PackageName}}.Repository
}

// New creates a Service.
func New(repo {{.PackageName}}.Repository) *Service { return &Service{repo: repo} }

func (s *Service) GetByID(ctx context.Context, id int64) (*{{.PackageName}}.{{.Name}}, error) {
	return s.repo.FindByID(ctx, id)
}

func (s *Service) List(ctx context.Context, page, pageSize int) ([]*{{.PackageName}}.{{.Name}}, int64, error) {
	if pageSize <= 0 { pageSize = defaultPageSize }
	if pageSize > maxPageSize { pageSize = maxPageSize }
	offset := (page - 1) * pageSize
	if offset < 0 { offset = 0 }
	return s.repo.List(ctx, offset, pageSize)
}

