	// TODO: add domain validation here
	e := &{{.PackageName}}.{{.Name}}{
		{{- range .Fields}}
		{{.GoName}}: in.{{.GoName}},
		{{- end}}
	}
	if err := s.repo.Create(ctx, e); err != nil {
		return nil, fmt.Errorf("{{.PackageName}}svc: create: %w", err)
	}
	return e, nil
}

func (s *Service) Update(ctx context.Context, id int64, in {{.PackageName}}.Update{{.Name}}Input) (*{{.PackageName}}.{{.Name}}, error) {
	e, err := s.repo.FindByID(ctx, id)
	if err != nil {
		return nil, err
	}
	{{- range .Fields}}
	if in.{{.GoName}} != nil { e.{{.GoName}} = *in.{{.GoName}} }
	{{- end}}
	if err := s.repo.Update(ctx, e); err != nil {
		return nil, fmt.Errorf("{{.PackageName}}svc: update: %w", err)
	}
	return e, nil
}

func (s *Service) Delete(ctx context.Context, id int64) error {
	if _, err := s.repo.FindByID(ctx, id); err != nil {
		return err
	}
	return s.repo.Delete(ctx, id)
}
