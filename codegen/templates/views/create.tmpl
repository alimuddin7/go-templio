package {{.PackageName}}views

import (
	"{{.ModulePath}}/internal/navigation"
	"{{.ModulePath}}/views/layout"
)

templ Create(navItems []navigation.Item, formErr error) {
	@layout.Base(layout.PageData{
		Title:       "New {{.Name}}",
		NavItems:    navItems,
		CurrentPath: "/{{.URLPrefix}}",
	}) {
		<div class="page-header">
			<div class="page-header-left">
				<a href="/{{.URLPrefix}}" class="btn btn--ghost btn--sm back-btn">
					<i data-lucide="arrow-left"></i> {{.PluralName}}
				</a>
				<h1 class="page-title">New {{.Name}}</h1>
			</div>
		</div>

		<div class="form-card">
			if formErr != nil {
				<div class="alert alert--error" role="alert">
					<i data-lucide="alert-circle"></i>
					{ formErr.Error() }
				</div>
			}

			<form method="POST" action="/{{.URLPrefix}}" class="form" id="create-{{.PackageName}}-form" novalidate>
				<div class="form-section">
					<h2 class="form-section-title">{{.Name}} Details</h2>
					<div class="form-grid">
						{{- range .Fields}}
						<div class="form-group">
							<label for="{{.FormName}}" class="form-label">{{.Label}}</label>
							<input
								type="{{.InputType}}"
								id="{{.FormName}}"
								name="{{.FormName}}"
								class="input"
								placeholder="{{.Placeholder}}"
							/>
						</div>
						{{- end}}
					</div>
				</div>
				<div class="form-actions">
					<a href="/{{.URLPrefix}}" class="btn btn--outline">Cancel</a>
					<button type="submit" class="btn btn--primary" id="submit-create-{{.PackageName}}">
						<i data-lucide="save"></i> Create {{.Name}}
					</button>
				</div>
			</form>
		</div>
	}
}
